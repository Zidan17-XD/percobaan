# Salin file ini menjadi .env lalu sesuaikan. JANGAN commit file .env ke GitHub.

# MySQL (XAMPP default)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=movieflix_db

# JWT - ganti dengan string acak yang panjang & rahasia
JWT_SECRET=ganti_dengan_secret_key_yang_panjang_dan_acak

# App
PORT=5000
CORS_ORIGIN=http://localhost:5173
